{
  "version": "1",
  "languages": [
    {
      "name": "elixir",
      "display_name": "Elixir",
      "description": "Elixir/Phoenix",
      "extensions": [".ex", ".exs"],
      "capabilities": ["grammar", "extract", "lsp"],
      "lsp_server": "elixir-ls"
    },
    {
      "name": "haskell",
      "display_name": "Haskell",
      "description": "Haskell",
      "extensions": [".hs"],
      "capabilities": ["grammar", "extract", "lsp"],
      "lsp_server": "haskell-language-server"
    },
    {
      "name": "dart",
      "display_name": "Dart",
      "description": "Dart/Flutter",
      "extensions": [".dart"],
      "capabilities": ["grammar", "extract", "lsp"],
      "lsp_server": "dart language-server"
    },
    {
      "name": "sql",
      "display_name": "SQL",
      "description": "SQL",
      "extensions": [".sql"],
      "capabilities": ["grammar", "extract"]
    },
    {
      "name": "ocaml",
      "display_name": "OCaml",
      "description": "OCaml",
      "extensions": [".ml", ".mli"],
      "capabilities": ["grammar", "extract", "lsp"],
      "lsp_server": "ocamllsp"
    },
    {
      "name": "r",
      "display_name": "R",
      "description": "R",
      "extensions": [".r", ".R"],
      "capabilities": ["grammar", "extract"]
    },
    {
      "name": "perl",
      "display_name": "Perl",
      "description": "Perl",
