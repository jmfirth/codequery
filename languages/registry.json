    {
      "name": "clojure",
      "display_name": "Clojure",
      "description": "Clojure",
      "extensions": [".clj", ".cljs", ".cljc"],
      "capabilities": ["grammar", "extract"]
    },
    {
      "name": "erlang",
      "display_name": "Erlang",
      "description": "Erlang/OTP",
      "extensions": [".erl", ".hrl"],
      "capabilities": ["grammar", "extract"]
    },
    {
      "name": "julia",
      "display_name": "Julia",
      "description": "Julia",
      "extensions": [".jl"],
      "capabilities": ["grammar", "extract", "lsp"],
      "lsp_server": "julia --project=@. -e 'using LanguageServer; runserver()'"
