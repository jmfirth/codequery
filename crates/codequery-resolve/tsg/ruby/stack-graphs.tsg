    (encoding)
    (subshell)
    (block_argument)
    (hash_splat_nil)
    (comment)
  ] @right
) {
  edge @right.before_scope -> @left.after_scope
}

;; =============================
;;  Assignment (local variables)
;; =============================

(assignment) @asgn {
  node @asgn.defs
  node @asgn.lexical_scope
  node @asgn.before_scope
  node @asgn.after_scope
  edge @asgn.lexical_scope -> @asgn.before_scope
}

;; Simple assignment: `result = expr`
(assignment
  left: (identifier) @name) @asgn
{
  node def
  attr (def) node_definition = @name
  edge @asgn.after_scope -> def
  edge @asgn.after_scope -> @asgn.before_scope
  edge @asgn.defs -> def
}

;; Constant assignment: `MAX_AGE = 150`
(assignment
  left: (constant) @name) @asgn
{
  node def
  attr (def) node_definition = @name
  edge @asgn.after_scope -> def
  edge @asgn.after_scope -> @asgn.before_scope
  edge @asgn.defs -> def
}

;; Wire right-hand side expressions in assignments.
(assignment
  right: (call) @rhs) @asgn
{
  edge @rhs.lexical_scope -> @asgn.lexical_scope
}

(assignment
  right: (identifier) @rhs) @asgn
{
  edge @rhs.lexical_scope -> @asgn.lexical_scope
}

(assignment
  right: (constant) @rhs) @asgn
{
  edge @rhs.lexical_scope -> @asgn.lexical_scope
}

;; Instance variable assignment: `@name = value`
(assignment
  left: (instance_variable) @_ivar) @asgn
{
  edge @asgn.after_scope -> @asgn.before_scope
}

;; =============================
;;  Operator assignment
;; =============================

(operator_assignment) @oasgn {
  node @oasgn.defs
  node @oasgn.lexical_scope
  node @oasgn.before_scope
  node @oasgn.after_scope
  edge @oasgn.after_scope -> @oasgn.before_scope
}

;; =============================
;;  Call expressions (references)
;; =============================

(call) @call_stub {
  node @call_stub.defs
  node @call_stub.lexical_scope
  node @call_stub.before_scope
  node @call_stub.after_scope
  edge @call_stub.after_scope -> @call_stub.before_scope
}

;; Simple method call without receiver: `greet("World")`
(call
  !receiver
  method: (identifier) @name) @call
{
  edge @name.lexical_scope -> @call.lexical_scope
}

;; Method call with receiver: `User.new('test')`, `self.greet()`
(call
  receiver: (_) @recv
  method: (identifier) @name) @call
{
  edge @recv.lexical_scope -> @call.lexical_scope
  edge @name.lexical_scope -> @call.lexical_scope
}

;; Wire arguments to the call's scope.
(call
  arguments: (argument_list
    [
      (identifier)
      (constant)
      (call)
      (string)
      (integer)
      (float)
      (simple_symbol)
      (array)
      (hash)
      (binary)
      (unary)
      (conditional)
      (parenthesized_statements)
      (instance_variable)
      (class_variable)
      (global_variable)
      (nil)
      (true)
      (false)
      (self)
      (super)
      (splat_argument)
      (hash_splat_argument)
      (pair)
      (element_reference)
      (scope_resolution)
      (lambda)
      (regex)
      (range)
      (string_array)
      (symbol_array)
      (block_argument)
      (hash_splat_nil)
      (chained_string)
      (delimited_symbol)
      (character)
      (complex)
      (rational)
      (encoding)
      (subshell)
      (block)
      (do_block)
      (rescue_modifier)
      (heredoc_body)
    ] @arg
  )
) @call {
  edge @arg.lexical_scope -> @call.lexical_scope
}

;; =============================
;;  Blocks: do_block and block
;; =============================

(do_block) @dblk {
  node @dblk.defs
  node @dblk.lexical_scope
  node @dblk.before_scope
  node @dblk.after_scope
  edge @dblk.after_scope -> @dblk.before_scope
}

(do_block
  parameters: (block_parameters) @params
  body: (body_statement) @body) @dblk
{
  edge @body.lexical_scope -> @dblk.lexical_scope
  edge @body.lexical_scope -> @params.defs
  attr (@body.lexical_scope -> @params.defs) precedence = 1
}

(do_block
  !parameters
  body: (body_statement) @body) @dblk
{
  edge @body.lexical_scope -> @dblk.lexical_scope
}

(block) @blk {
  node @blk.defs
  node @blk.lexical_scope
  node @blk.before_scope
  node @blk.after_scope
  edge @blk.after_scope -> @blk.before_scope
}

(block
  parameters: (block_parameters) @params
  body: (block_body) @body) @blk
{
  edge @body.lexical_scope -> @blk.lexical_scope
  edge @body.lexical_scope -> @params.defs
  attr (@body.lexical_scope -> @params.defs) precedence = 1
}

(block
  !parameters
  body: (block_body) @body) @blk
{
  edge @body.lexical_scope -> @blk.lexical_scope
}

;; block_body stub
(block_body) @bb {
  node @bb.defs
  node @bb.lexical_scope
  node @bb.before_scope
  node @bb.after_scope
  edge @bb.lexical_scope -> @bb.before_scope
}

;; =============================
;;  require_relative as import
;; =============================

;; `require_relative 'models'` creates an import edge from ROOT_NODE
;; so that definitions from the required file are visible.
(call
  method: (identifier) @_req_method
  arguments: (argument_list (string) @path)) @req_call
{
  ;; We only act on require_relative; other calls fall through harmlessly.
  ;; The string node's text includes quotes, which is fine for the reference.
  node ref
  attr (ref) node_reference = @path
  edge ref -> ROOT_NODE
  edge @req_call.lexical_scope -> ref
}

;; =============================
;;  Expression / literal stubs
;; =============================
;;
;; These nodes need .defs, .lexical_scope, .before_scope, .after_scope so they
;; can participate in parent-child wiring without causing "Undefined scoped
;; variable" errors.

[
  (string)
  (integer)
  (float)
  (simple_symbol)
  (array)
  (hash)
  (nil)
  (true)
  (false)
  (self)
  (super)
  (binary)
  (unary)
  (conditional)
  (parenthesized_statements)
  (instance_variable)
  (class_variable)
  (global_variable)
  (splat_argument)
  (hash_splat_argument)
  (element_reference)
  (scope_resolution)
  (pair)
  (regex)
  (range)
  (heredoc_body)
  (heredoc_beginning)
  (string_array)
  (symbol_array)
  (bare_string)
  (bare_symbol)
  (lambda)
  (argument_list)
  (chained_string)
  (delimited_symbol)
  (character)
  (complex)
  (rational)
  (encoding)
  (subshell)
  (block_argument)
  (hash_splat_nil)
  (rescue_modifier)
] @expr {
  node @expr.defs
  node @expr.lexical_scope
  node @expr.before_scope
  node @expr.after_scope
  edge @expr.after_scope -> @expr.before_scope
}

;; =============================
;;  Statement stubs
;; =============================

[
  (if)
  (unless)
  (while)
  (until)
  (for)
  (case)
  (begin)
  (return)
  (yield)
  (break)
  (next)
  (if_modifier)
  (unless_modifier)
  (while_modifier)
  (until_modifier)
  (singleton_class)
  (alias)
  (undef)
  (redo)
  (retry)
  (begin_block)
  (end_block)
  (empty_statement)
  (case_match)
] @stmt {
  node @stmt.defs
  node @stmt.lexical_scope
  node @stmt.before_scope
  node @stmt.after_scope
  edge @stmt.after_scope -> @stmt.before_scope
}
